; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Neon Possum"
config/version="0.1.0"
run/main_scene="uid://main"
config/features=PackedStringArray("4.7", "Forward Plus")
config/run/main_scene="res://scenes/main.tscn"

[autoload]

Sfx="*res://scripts/sfx.gd"
SaveData="*res://scripts/save_data.gd"
Missions="*res://scripts/missions.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/size/resizable=false
window/size/window_width_override=540
window/size/window_height_override=960
window/stretch/mode="canvas_items"
window/handheld/orientation=1

[input]

swipe_left={
"deadzone": 0.5,
"events": []
}
swipe_right={
"deadzone": 0.5,
"events": []
}
swipe_up={
"deadzone": 0.5,
"events": []
}
swipe_down={
"deadzone": 0.5,
"events": []
}
